{
  "name": "devbox-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite dev",
    "dev:cf": "bun run build && wrangler dev worker.js",
    "build": "vite build && bun run src/cloudflare/postbuild-worker.ts",
    "preview": "wrangler dev worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen": "wrangler types",
    "build:template:dev": "bun run src/e2b/build-template.ts devbox-dev",
    "build:template:prod": "bun run src/e2b/build-template.ts devbox",
    "sandbox:create": "bun run src/e2b/create-sandbox.ts",
    "sandbox:list": "bun run src/e2b/list-sandboxes.ts",
    "sandbox:connect": "bun run src/e2b/connect-sandbox.ts",
    "sandbox:ssh": "bun run src/e2b/ssh-sandbox.ts",
    "sandbox:pause": "bun run src/e2b/pause-sandbox.ts",
    "sandbox:resume": "bun run src/e2b/resume-sandbox.ts",
    "sandbox:kill": "bun run src/e2b/kill-sandbox.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "e2b": "^2.14.1",
    "lucide-svelte": "^0.577.0",
    "phosphor-svelte": "^3.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@sveltejs/adapter-cloudflare": "^7.2.6",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/bun": "^1.3.1",
    "bits-ui": "^2.16.3",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwind-variants": "^3.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.63.0"
  }
}
