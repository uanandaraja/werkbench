{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "rewriteRelativeImportExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "types": [
      "./worker-configuration.d.ts"
    ]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "worker-configuration.d.ts",
    "vite.config.ts",
    "svelte.config.js"
  ],
  "exclude": [
    "src/e2b/**/*.ts",
    "src/cloudflare/**/*.ts",
    ".svelte-kit/**/*"
  ]
}
